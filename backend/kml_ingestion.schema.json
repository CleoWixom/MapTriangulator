{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maptriangulator.local/schemas/kml-ingestion.schema.json",
  "title": "KML Ingestion Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cell_sites", "signal_samples", "warnings"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "cell_sites": {
      "type": "array",
      "items": { "$ref": "#/$defs/cellSite" }
    },
    "signal_samples": {
      "type": "array",
      "items": { "$ref": "#/$defs/signalSample" }
    }
  },
  "$defs": {
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mcc", "mnc"],
      "properties": {
        "mcc": { "type": "integer", "minimum": 1 },
        "mnc": { "type": "integer", "minimum": 0 }
      }
    },
    "cellSite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "radio", "lat", "lon", "operator", "lac", "cid", "psc", "station_id"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "radio": { "type": "string", "minLength": 1 },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "operator": { "$ref": "#/$defs/operator" },
        "lac": { "type": "integer", "minimum": 0 },
        "cid": { "type": "string", "minLength": 1 },
        "rnc": { "type": "integer" },
        "psc": { "type": "integer", "minimum": 0 },
        "station_id": { "type": "string", "pattern": "^\\d+-\\d+-\\d+-[^-]+-\\d+$" },
        "style_url": { "type": "string" },
        "distance_m": { "type": "number" },
        "accuracy": { "type": "number", "minimum": 0 },
        "change_type": { "type": "string" },
        "timestamp": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "signalSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dbm", "lat", "lon", "operator", "lac", "cid", "psc", "station_id"],
      "properties": {
        "dbm": { "type": "number" },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "operator": { "$ref": "#/$defs/operator" },
        "lac": { "type": "integer", "minimum": 0 },
        "cid": { "type": "string", "minLength": 1 },
        "rnc": { "type": "integer" },
        "psc": { "type": "integer", "minimum": 0 },
        "station_id": { "type": "string", "pattern": "^\\d+-\\d+-\\d+-[^-]+-\\d+$" },
        "style_url": { "type": "string" },
        "accuracy": { "type": "number", "minimum": 0 },
        "change_type": { "type": "string" },
        "timestamp": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
